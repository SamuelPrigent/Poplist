{
  "name": "poplist",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n \"hono,next\" -c \"green,blue\" \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm --workspace=backend run typecheck && npm --workspace=frontend run typecheck",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "npm --workspace=backend run test",
    "test:e2e": "npm --workspace=frontend run test:e2e",
    "test:e2e:headed": "npm --workspace=frontend run test:e2e:headed",
    "test:e2e:ui": "npm --workspace=frontend run test:e2e:ui",
    "db-push-test": "npm --workspace=backend run db-push-test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "turbo": "^2",
    "wait-on": "^9.0.10"
  }
}
