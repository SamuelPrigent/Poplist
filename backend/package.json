{
  "name": "poplist-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db-push": "drizzle-kit push",
    "db-push-prod": "dotenv -e .env.prod -- drizzle-kit push",
    "db-push-test": "dotenv -e .env.test -- drizzle-kit push --force",
    "db-studio": "drizzle-kit studio",
    "db-pull": "drizzle-kit pull",
    "db-generate": "drizzle-kit generate",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "npm run typecheck && dotenv -e .env.test -- vitest run",
    "test:unit": "dotenv -e .env.test -- vitest run tests/unit",
    "test:integration": "dotenv -e .env.test -- vitest run tests/integration",
    "test:watch": "dotenv -e .env.test -- vitest",
    "test:server": "dotenv -e .env.test -- tsx tests/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@poplist/shared": "*",
    "bcrypt": "^6.0.0",
    "bottleneck": "^2.19.5",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.5.0",
    "hono": "^4.11.8",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
